# JWT Secret - OBRIGATÓRIO! Use um valor aleatório e seguro em produção
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=COLOQUE_UM_JWT_SECRET_SEGURO_AQUI_32_CARACTERES_MINIMO

# URLs
BASE_URL=http://localhost:3000
FRONTEND_URL=http://localhost:5173

# Porta do servidor
PORT=3000
